# ====================================
# Neesh AI Environment Configuration Template
# ====================================
# COPY THIS FILE TO .env AND REPLACE WITH YOUR ACTUAL CREDENTIALS
# NEVER COMMIT .env FILES TO VERSION CONTROL

# ====================================
# Database Configuration (Supabase)
# ====================================
SPRING_DATASOURCE_URL=jdbc:postgresql://your-project.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
SPRING_DATASOURCE_USERNAME=postgres.your_project_ref
SPRING_DATASOURCE_PASSWORD=your_database_password

# ====================================
# Supabase Authentication & Services
# ====================================
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ====================================
# AI Service Configuration
# ====================================
AI_SERVICE_URL=http://localhost:3000
AI_SERVICE_INTERNAL_API_KEY=your-secure-internal-api-key

# ====================================
# LLM Provider Configuration
# ====================================
# OpenAI API for embeddings (text-embedding-3-small)
OPENAI_API_KEY=sk-proj-your_openai_api_key_here
# Gemini API for chat responses
GEMINI_API_KEY=your_gemini_api_key_here

# ====================================
# AI Service Environment (.env for ai-service/)
# ====================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
OPENAI_API_KEY=sk-proj-your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
BACKEND_URL=http://localhost:8081
PORT=3000
INTERNAL_API_KEY=your-secure-internal-api-key

# ====================================
# Storage Configuration
# ====================================
SUPABASE_STORAGE_BUCKET=documents

# ====================================
# Email Configuration (Optional)
# ====================================
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=Neesh AI <hello@neeshai.com>

# ====================================
# Security Configuration
# ====================================
API_KEY_ENCRYPTION_SECRET=your-32-character-encryption-secret-key

# ====================================
# Admin Configuration
# ====================================
ADMIN_MASTER_USERNAME=admin@neeshai.com
ADMIN_MASTER_PASSWORD=your_secure_admin_password

# ====================================
# Payment Configuration (Optional)
# ====================================
CASHFREE_APP_ID=your-cashfree-app-id
CASHFREE_SECRET_KEY=your-cashfree-secret
CASHFREE_API_URL=https://sandbox.cashfree.com/pg

# ====================================
# Frontend Configuration
# ====================================
APP_FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ====================================
# Debug Configuration
# ====================================
APP_DEBUG=false